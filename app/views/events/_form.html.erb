<div class="container mt-5">
  <h2 class="text-center text-primary fw-bold">Create New Event</h2>

  <div class="card shadow-lg border-0 rounded-4 p-4 mt-4">
    <%= form_with(model: @event, local: true, html: { multipart: true }) do |form| %>
      <% if @event.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@event.errors.count, "error") %> prevented this event from being saved:</h4>
          <ul>
            <% @event.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= form.label :event_name, class: "form-label fw-bold" %>
        <%= form.text_field :event_name, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= form.label :description, class: "form-label fw-bold" %>
        <%= form.text_area :description, class: "form-control", rows: 3 %>
      </div>

      <div class="mb-3">
        <%= form.label :date, class: "form-label fw-bold" %>
        <%= form.datetime_field :date, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= form.label :location, class: "form-label fw-bold" %>
        <%= form.text_field :location, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= form.label :venue, class: "form-label fw-bold" %>
        <%= form.text_field :venue, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= form.label :total_seats, class: "form-label fw-bold" %>
        <%= form.number_field :total_seats, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= form.label :price, class: "form-label fw-bold" %>
        <%= form.number_field :price, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= form.label :category, class: "form-label fw-bold" %>
        <%= form.text_field :category, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= form.label :image, "Upload Event Image", class: "form-label fw-bold" %>
        <%= form.file_field :image, class: "form-control" %>
      </div>

      <div class="text-center">
        <%= form.submit "Create Event", class: "btn btn-primary px-4 fw-bold" %>
      </div>
    <% end %>
  </div>
</div>
