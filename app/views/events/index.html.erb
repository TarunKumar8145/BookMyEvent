<div class="container mt-5">
  <!-- Search Query Heading -->
  <h2 class="text-center text-primary fw-bold">
    "<%= params[:query] %>"
  </h2>

  <!-- Events Heading -->
  <h1 class="text-center text-dark mt-4 fw-bold">Discover Events</h1>

  <div id="events" class="row g-4 mt-4 justify-content-center">
    <% if @events.present? %>
      <% @events.each do |event| %>
        <div class="col-lg-4 col-md-6 col-sm-12">
          <div class="card event-card shadow border-0">
            <!-- Event Image -->
            <% if event.image.attached? %>
              <%= image_tag event.image, class: "card-img-top img-fluid event-img" %>
            <% else %>
              <img src="https://via.placeholder.com/300x200?text=No+Image" class="card-img-top img-fluid event-img">
            <% end %>

            <div class="card-body text-center bg-white">
              <h5 class="card-title fw-bold text-dark"><%= event.event_name %></h5>

              <% if current_user&.admin? %>
                <p>
                  <%= link_to "View Details", event_path(event), class: "btn btn-outline-primary btn-sm fw-bold px-3" %>
                </p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center text-danger fs-5 mt-4 fw-bold">No events found.</p>
    <% end %>
  </div>

  <!-- New Event Button for Admin -->
  <% if current_user&.admin? %>
    <div class="text-center mt-4">
      <%= link_to "Add New Event", new_event_path, class: "btn btn-success fw-bold px-4 py-2 rounded-pill shadow-lg" %>
    </div>
  <% end %>
</div>

<style>
  /* Modern Event Card */
.event-card {
  border-radius: 15px;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.event-card:hover {
  transform: translateY(-5px);
  box-shadow: 0px 10px 25px rgba(0, 0, 0, 0.15);
}

/* Event Image Styling */
.event-img {
  height: 220px;
  object-fit: cover;
  border-top-left-radius: 15px;
  border-top-right-radius: 15px;
}

/* Button Hover Effect */
.btn-outline-primary:hover {
  background-color: #007bff;
  color: white;
}

/* Admin Button Styling */
.btn-success {
  background: linear-gradient(to right, #28a745, #218838);
  border: none;
}

.btn-success:hover {
  background: linear-gradient(to right, #218838, #1e7e34);
}

  </style>