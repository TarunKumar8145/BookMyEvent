<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
  <div class="card shadow-lg p-4 w-50">
    <div class="card-body text-center">
      <h3 class="text-success">Payment Successful!</h3>
      <p>Your booking has been confirmed. Here are your details:</p>

      <p><strong>Event:</strong> <%= @booking.event.event_name %></p>
      <p><strong>Date:</strong> <%= @booking.event.date.strftime('%d %b %Y') %></p>
      <p><strong>Location:</strong> <%= @booking.event.location %></p>
      <p><strong>Tickets Booked:</strong> <%= @booking.tickets %></p>
      <p><strong>Total Amount Paid:</strong> ₹<%= @booking.total_price %></p>

      <%= link_to "Back to Events", gallery_index_path, class: "btn btn-primary mt-3" %>
    </div>
  </div>
</div>
