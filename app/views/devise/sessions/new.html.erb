<div class="container d-flex justify-content-center align-items-center vh-100">
  <div class="card shadow-lg p-4 rounded" style="max-width: 400px; width: 100%; background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px);">
    
    <h2 class="text-center text-white fw-bold">Log In</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "needs-validation" }) do |f| %>
      
      <div class="mb-3">
        <%= f.label :email, class: "form-label text-light" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "Enter your email" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, class: "form-label text-light" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "Enter your password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-check mb-3">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, class: "form-check-label text-light" %>
        </div>
      <% end %>

      <div class="d-grid">
        <%= f.submit "Log in", class: "btn btn-warning fw-bold" %>
      </div>
    <% end %>

    <div class="text-center mt-3">
      <%= link_to "Sign up", new_registration_path(resource_name), class: "text-warning fw-bold text-decoration-none" %> | 
      <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-warning fw-bold text-decoration-none" %>
    </div>
  </div>
</div>

<style>
  body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(to right, #6a11cb, #2575fc);
    color: white;
  }

  .form-control {
    background: rgba(255, 255, 255, 0.3);
    color: white;
    border: none;
  }

  .form-control::placeholder {
    color: rgba(255, 255, 255, 0.7);
  }

  .form-control:focus {
    background: rgba(255, 255, 255, 0.5);
    box-shadow: none;
  }

  .btn-warning {
    background-color: #ff9800;
    border: none;
  }

  .btn-warning:hover {
    background-color: #e68900;
  }

  .text-warning:hover {
    text-decoration: underline;
  }
</style>
